# edge-tts voice — see `edge-tts --list-voices` for options.
# Recommended: en-US-AndrewMultilingualNeural (warm, conversational, US)
# Alternative: en-GB-RyanNeural (UK accent)
TTS_VOICE=en-US-AndrewMultilingualNeural

# Optional: adjust speaking rate ("-5%", "+0%", "+10%" etc — default "-5%")
TTS_RATE=-5%
